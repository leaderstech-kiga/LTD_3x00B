 117   1              subb    a,#0                        // 1cycle
 118   1              mov     r6,a                        // 1cycle
 119   1              jnc     _nop_20us_delay_loop        // 2cycle
 120   1      
 121   1          _nop_20us_delay_loop_end:
 122   1              nop                                 // 1cycle
 123   1              
 124   1          #pragma endasm
 125   1                                                  // ret 2cycle
