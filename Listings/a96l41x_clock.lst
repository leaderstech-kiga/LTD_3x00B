  58          /**
  59          * @brief  Initialize System Clock peripheral
  60          * @param    clock_sel This parameter contains the selection of clock.
  61          * @return   None
  62          */
  63          void Clock_Initial(uint8_t clock_sel)
  64          {
  65   1          uint8_t temp_reg;
  66   1        if(clock_sel <= HFI4_DIV1)
  67   1        {
  68   2          /* Internal 4Mhz RC OSC for system clock */
  69   2          SCCR  = SCCR_IRC_4MHZ;            
  70   2          /* Internal RC Oscillator Post-divider Select INT-RC/n (32/n MHz) */
  71   2          temp_reg = OSCCR;
  72   2          temp_reg  &= ~(0x3 << 3);
  73   2          temp_reg  |= (clock_sel << 3) | OSCCR_HIRCE_EN;
  74   2          OSCCR = temp_reg;
  75   2        }
  76   1        else if(clock_sel == LFI)
  77   1        {
  78   2          /* Internal 32khz RC OSC for system clock */
  79   2            OSCCR |= OSCCR_LFIRCE_EN;
  80   2              NOP_20us_Delay(5000);
  81   2          SCCR  = SCCR_IRC_32KHZ; 
  82   2          temp_reg = OSCCR;
  83   2          temp_reg  |= OSCCR_HIRCE_DIS;
  84   2          OSCCR = temp_reg;
  85   2        }
  86   1      }
  87          
  88          /**
  89          * @brief  Controls clock frequency selection and oscillator operation.
  90          * @param    osc_sel   This parameter contains the selection of Oscillator.
  91          *
  92          *         - HFIRC  = 0
  93          *         - LFIRC  = 1
  94          * @param    hsirc_div   This parameter contains the Post-divider Selection of Internal RC Oscillator.
  95          *
  96          *         - HFIRC4_DIV8 = 0
  97          *         - HFIRC4_DIV4 = 1 
  98          *         - HFIRC4_DIV2 = 2
  99          *         - HFIRC4_DIV1 = 3
 100          * @param    osc_enable  This parameter contains the enable of oscillator.
 101          *
 102          *         - OSC_DIS  = 0
 103          *         - OSC_EN   = 1
 104          * @return   None
 105          */
 106          void Clock_ConfigureOSC(uint8_t osc_sel, uint8_t hsirc_div, uint8_t osc_enable)
 107          {
 108   1        uint8_t temp_reg;
 109   1        
 110   1        if(osc_sel == LFIRC)
 111   1        {
 112   2              if(osc_enable == OSC_DIS)
 113   2              {
 114   3            temp_reg = OSCCR;
 115   3                  /* Disable Low Frequency(32kHz) Internal RC OSC for system clock */
 116   3                  temp_reg &= ~(osc_enable << 7);
C51 COMPILER V9.54   A96L41X_CLOCK                                                         04/21/2026 18:38:47 PAGE 3   

 117   3              }
 118   2              else if(osc_enable == OSC_EN)
 119   2              {
 120   3                  /* Enable Low Frequency(32kHz) Internal RC OSC for system clock */
 121   3                  OSCCR |= (0x1 << 7);          
 122   3              }
 123   2        }
 124   1        else if(osc_sel == HFIRC)
 125   1        {
 126   2              if(osc_enable == OSC_DIS)
 127   2              {
 128   3                  /* Disable High Frequency(4MHz) Internal RC OSC for system clock */
 129   3                  OSCCR |= (0x1 << 2);          
 130   3              }
 131   2              else if(osc_enable == OSC_EN)
 132   2              {
 133   3            temp_reg = OSCCR;
 134   3                  /* Enable High Frequency(4MHz) Internal RC OSC for system clock */
 135   3                  temp_reg &= ~(osc_enable << 2);
 136   3                  
 137   3                  temp_reg &= ~(0x3<<3);
 138   3                  temp_reg |= (hsirc_div<<3);
 139   3            
 140   3            OSCCR = temp_reg;
 141   3              }
 142   2        }
 143   1      }
