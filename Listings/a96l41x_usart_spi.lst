  63          /**
  64          * @brief    Initialize usart(spi) peripheral
  65          * @param   mode This parameter contains the enable of master or slave mode(SPI). 
  66          *
  67          *           - SPI_SLAVE_MODE    = 0
  68          *           - SPI_MASTER_MODE     = 1
  69          * @param   speed      This parameter contains the buadrate of SPI.
  70          * @param   first_bit  This parameter contains the transmitted first as SPI.
  71          *
  72          *           - SPI_LSB     = 0
  73          *         - SPI_MSB   = 1
  74          * @param   cpol This parameter contains the polarity(CPOL) as SPI. 
  75          *
  76          *           - SPI_CPOL_LOW  = 0
  77          *         - SPI_CPOL_HIGH = 1
  78          * @param   cpha This parameter contains the phase(CPHA) as SPI. 
  79          *
  80          *           - SPI_CPHA_1EDGE = 0
  81          *         - SPI_CPHA_2EDGE = 1
  82          * @param   direction  This parameter contains the enable of transmit or receive mode(SPI). 
  83          *
  84          *           - SPI_TX_RX_MODE    = 0
  85          *           - SPI_RX_MODE     = 1
  86          *         - SPI_TX_MODE       = 2
  87          * @param   ss_mode  This parameter contains the enable of SS function(SPI).
  88          *
  89          *           - SPI_SS_HW_DISABLE     = 0
  90          *         - SPI_SS_HW_ENABLE      = 1
  91          * @return   None
  92          */
  93          void USART_SPI_Initial(uint8_t mode, uint32_t speed, uint8_t first_bit, uint8_t cpol, uint8_t cpha, uint8_
             -t direction, uint8_t ss_mode)
  94          {
  95   1        uint32_t buadrate_val = 0;
  96   1        uint8_t temp_reg;
  97   1        
  98   1        spi_writeNum0 = 0;
  99   1        spi_readNum0 = 0;
 100   1        
 101   1        /*calculate baudrate speed*/
 102   1        buadrate_val = ((Clock_GetSystemFreq() / speed )  >> 1) * 10;
 103   1        
 104   1        buadrate_val = ((buadrate_val + 5) / 10) - 1; //round
 105   1          
 106   1        temp_reg = USTCR2;
 107   1        if(direction == SPI_RX_MODE)
 108   1          temp_reg |= RXE;  
 109   1        else if(direction == SPI_TX_MODE)
 110   1          temp_reg |= TXE;
 111   1        else
 112   1          temp_reg |= (RXE | TXE);
 113   1          
 114   1        temp_reg |= USTEN;
 115   1          
C51 COMPILER V9.54   A96L41X_USART_SPI                                                     04/16/2026 10:27:07 PAGE 3   

 116   1        USTST |= SOFTRST;     // USART block reset
 117   1        USTCR1 |= ((0x3 << 6) | (first_bit << 2) | (cpha << 1) | (cpol << 0));  //SPI mode
 118   1        USTCR3 |= ((mode << 7) | (ss_mode << 4));
 119   1        USTBD = buadrate_val;
 120   1        USTCR2 = temp_reg;
 121   1        
 122   1      }
