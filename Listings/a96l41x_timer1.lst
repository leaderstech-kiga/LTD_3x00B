  57          /**
  58          * @brief    Initialize timer1 peripheral
  59          * @param   mode   This parameter contains the mode of timer.
  60          *
  61          *         - T1_COUNTER_MODE           = 0
  62          *         - T1_CAPTURE_MODE           = 1
  63          *         - T1_PPG_ONESHOT_MODE           = 2
  64          *         - T1_PPG_REPEAT_MODE          = 3
  65          * @param   freq This parameter contains the selection of frequency.
  66          *
  67          *         - TIMER1_DIV2048            = 0
  68          *         - TIMER1_DIV512             = 1
  69          *         - TIMER1_DIV64              = 2
  70          *         - TIMER1_DIV8               = 3
  71          *         - TIMER1_DIV4             = 4
  72          *         - TIMER1_DIV2             = 5
  73          *         - TIMER1_DIV1             = 6
  74          *         - TIMER1_EC2              = 7
  75          * @return   None
  76          */
  77          void Timer1_Initial(uint8_t mode, uint8_t freq)
  78          {
  79   1        uint8_t temp_reg, temp_reg2;
  80   1        
  81   1        temp_reg = T1CRH;
  82   1        /* Set timer mode & frequency source */
  83   1        temp_reg &= ~(0x3 << 4);
  84   1        temp_reg |= ((mode << 4) | (0x1 << 0));
  85   1        
  86   1        temp_reg2 = T1CRL;
  87   1        temp_reg2 &= ~((0x7 << 5) | (0x1 << 0));
  88   1        if(mode >= T1_PPG_ONESHOT_MODE)
  89   1          temp_reg2 |= (freq << 5);
  90   1        else
  91   1          temp_reg2 |= ((freq << 5) | (0x1 << 0));
  92   1        
  93   1        T1CRH = temp_reg;
  94   1        T1CRL = temp_reg2;
  95   1      }
  96          
