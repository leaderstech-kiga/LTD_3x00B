  57          /**
  58          * @brief    Initialize OPAMP peripheral
  59          * @param   gain_1sel      This parameter contains the selection of OP1 gain select .
  60          *
  61          *     - GAIN1_DIS   = 0
  62          *     - X1      = 1
  63          *     - X2      = 2
  64          *     - X10       = 3
  65          *     - X15       = 4
  66          *     - X20       = 5
  67          *     - X30       = 6
  68          *     - X60       = 7
  69          * @param   gain_0sel    This parameter contains the selection of OP0 gain select.
  70          *
  71          *     - GAIN0_DIS   = 0
  72          *     - X5      = 1
  73          *     - X10       = 2
  74          *     - X20       = 3
  75          * @param   chp_clk    This parameter contains the selection of OPAMP chopper clock select.
  76          *
  77          *     - 125KHz    = 0
  78          *     - 167KHz    = 1
  79          * @return   None
  80          */
  81          void OPAMP_Initial(uint8_t gain_1sel, uint8_t gain_0sel, uint8_t chp_clk)
  82          {
  83   1        uint8_t temp_reg, temp_reg2;
  84   1        
  85   1        temp_reg = AMPCR1;
  86   1        temp_reg &= ~(0xFF);
  87   1        temp_reg |= ((gain_1sel << 4) | (gain_0sel << 0));
  88   1        
  89   1        AMPCR1 = temp_reg;
  90   1        
  91   1        temp_reg2 = CHPCR;
  92   1        temp_reg2 &= ~(0xFF);
  93   1        temp_reg2 |= (chp_clk << 0);
  94   1        
  95   1        CHPCR = temp_reg2;
  96   1        
  97   1      }
  98          
  99          /**
 100          * @brief    Enables or disables the OP1 peripheral.
 101          * @param   enable   This parameter contains the enable of this function. 
 102          *
 103          *     - FALSE   = 0
 104          *     - TRUE    = 1
 105          * @return   None
 106          */
 107          void OP1_Enable(uint8_t enable)
 108          {
 109   1        if(enable == TRUE)
 110   1        {
 111   2          AMPCR1 |= (1 << 7);
 112   2        }
 113   1        else
 114   1        {
 115   2          AMPCR1 &= ~(1 << 7);
 116   2        }
C51 COMPILER V9.54   A96L41X_OPAMP                                                         04/10/2026 17:18:31 PAGE 3   

 117   1      }
