 190          /**
 191          * @brief    Get data of ADC conversion for ADC interrupt.
 192          * @param   adc_data   This parameter contains the data of conversion ADC.
 193          * @param   count    This parameter contains the number of count.
 194          * @return   None
 195          */
 196          void ADC_GetDataWithInterrupt(uint16_t *adc_data, uint8_t count)
 197          {
 198   1        adc_count = count;
 199   1        adc_buff = (uint16_t*)adc_data;
 200   1        buff_cnt = 0;
 201   1        
 202   1        ADC_ConfigureInterrupt(TRUE);
 203   1      
 204   1        if( ((ADCCRH & 0x08) == 0x00)) //SW trigger
 205   1        {
 206   2          ADC_StartSoftwareTrigger();
 207   2        }
 208   1        
 209   1        while(0 < adc_count);  //adc interrupt subroutine execute
 210   1      
 211   1      }
 212          
 213          /**
 214          * @brief    Get data of ADC conversion for ADC polling.
 215          * @param   adc_data   This parameter contains the data of conversion ADC.
 216          * @param   count    This parameter contains the number of count.
 217          * @return   None
 218          */
 219          void ADC_GetDataWithPolling(uint16_t *adc_data, uint8_t count)
 220          {
 221   1        uint8_t i;
 222   1        
 223   1        for(i = 0; i < count; i++)
 224   1        {
 225   2          if( ((ADCCRH & 0x08) == 0x00) ) //SW trigger
 226   2            ADC_StartSoftwareTrigger();
 227   2            
 228   2          while(!(ADC_GetConversionStatus()));
 229   2            
 230   2          adc_data[i] = ADCDR;
 231   2        }
 232   1      }
