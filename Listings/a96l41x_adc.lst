 234          /**
 235          * @brief    Configure the enable or disable ADC interrupt.
 236          * @param   enable   This parameter contains the enable of this function. 
 237          *
 238          *     - FALSE = 0
 239          *     - TRUE  = 1
 240          * @return   None
C51 COMPILER V9.54   A96L41X_ADC                                                           04/16/2026 10:27:06 PAGE 5   

 241          */
 242          void ADC_ConfigureInterrupt(uint8_t enable)
 243          {
 244   1        if(enable == TRUE)
 245   1        {
 246   2          IE1  |= 0x01; 
 247   2        }
 248   1        else
 249   1        {
 250   2          ADCCRH &= ~0x80;
 251   2          IE1 &= ~0x01;
 252   2        }
 253   1      }
 254          
 255          /**
 256          * @brief    Clear the ADC interrupt status.
 257          * @param      None
 258          * @return   None
 259          */
 260          void ADC_ClearInterruptStatus()
 261          {
 262   1        ADCCRH &= ~0x80;
 263   1      }
