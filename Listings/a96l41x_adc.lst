 143          /**
 144          * @brief    Enables the ADC Start conversion(For software trigger).
 145          * @param      None
 146          * @return   None
 147          */
 148          void ADC_StartSoftwareTrigger()
 149          {
 150   1        ADCCRL |= (1 << 6);
 151   1      }
