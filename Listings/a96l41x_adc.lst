 123          /**
 124          * @brief    Enables or disables the ADC peripheral.
 125          * @param   enable   This parameter contains the enable of this function. 
 126          *
 127          *     - FALSE   = 0
 128          *     - TRUE    = 1
 129          * @return   None
 130          */
 131          void ADC_Enable(uint8_t enable)
 132          {
 133   1        if(enable == TRUE)
 134   1        {
 135   2          ADCCRL |= (1 << 7);
 136   2        }
 137   1        else
 138   1        {
 139   2          ADCCRL &= ~(1 << 7);
 140   2        }
 141   1      }
