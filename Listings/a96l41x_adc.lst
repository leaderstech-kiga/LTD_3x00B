 265          
 266          void ADC_Int_Handler(void) interrupt ADC_VECT
 267          {
 268   1        if(((ADCCRH & 0x08) == 0x00) && (adc_count != 0)) //SW trigger
 269   1          ADC_StartSoftwareTrigger();
 270   1        
 271   1        adc_count--;
 272   1        adc_buff[buff_cnt++] = ADCDR;
 273   1        
 274   1        if(adc_count == 0)
 275   1          ADC_ConfigureInterrupt(FALSE);
 276   1      }
