 162          *     - ADC_CH5   = 5
 163          *     - ADC_CH6   = 6
 164          *     - ADC_OP0OUT  = 9
 165          *     - ADC_OP1OUT  = 10
 166          *     - ADC_VBGR  = 15
 167          * @return   None
 168          */
 169          void ADC_SelectChannel(uint8_t channel)
 170          {
 171   1        uint8_t temp_reg;
 172   1        
 173   1        temp_reg = ADCCRL;
 174   1        temp_reg &= ~(0xF << 0);
 175   1        temp_reg |= channel;
 176   1        
