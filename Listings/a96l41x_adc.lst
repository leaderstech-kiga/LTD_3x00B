  59          /**
  60          * @brief    Initialize ADC peripheral
  61          * @param   clock_sel      This parameter contains the selection of ADC converter clock (fx <= 8MHz).
  62          *
  63          *     - ADC_CLK_4M    = 0
  64          *     - ADC_CLK_2M    = 1
  65          *     - ADC_CLK_1M    = 2
  66          *     - ADC_CLK_0_5M    = 3
  67          * @param   trigger_sel    This parameter contains the selection of ADC trigger source.
  68          *
  69          *     - ADC_SW_TRIG   = 0
  70          *     - ADC_T0_TRIG     = 1
  71          * @param   ref_voltage    This parameter contains the selection of ADC reference voltage.
  72          *
  73          *     - ADC_INTERNAL_REF  = 0
  74          *     - ADC_LDO_REF   = 1
  75          * @param   align_sel    This parameter contains the selection of ADC data align. 
  76          *
  77          *     - ADC_MSB       = 0
  78          *     - ADC_LSB       = 1
  79          * @return   None
  80          */
  81          void ADC_Initial(uint8_t clock_sel, uint8_t trigger_sel, uint8_t ref_voltage, uint8_t align_sel)
  82          {
  83   1          /*  The A/D converter needs at least 14 us for conversion time.
  84   1              So you must set the conversion time more than 14 us.
  85   1              If the ADC conversion time is set short, the resolution is degraded.
  86   1          
  87   1              ** ADC Conversion clock = ADCLK * 28 clocks
  88   1              
  89   1          Example)
  90   1              fx=2Mhz, CKSEL = 2M,  ADC Clock source(@2Mhz) = 0.5us
  91   1              28 clock x 0.5us = 14us at 2Mhz
  92   1          */
  93   1        uint8_t temp_reg, temp_reg2;
  94   1        
  95   1          if(clock_sel == 0){
  96   2          clock_sel =1;
  97   2        }
  98   1          
  99   1        temp_reg = ADCCRH;
 100   1        temp_reg &= ~(0xFF);
 101   1        temp_reg |= ((trigger_sel << 3) | (align_sel << 2) | (clock_sel << 0));
 102   1        
 103   1        temp_reg2 = ADCCRL;
 104   1        temp_reg2 &= ~(0xFF);
 105   1        temp_reg2 |= ((1 << 7) | (ref_voltage << 5));  //ADC Enable + ref_Voltage
 106   1        
 107   1        ADCCRH = temp_reg;
 108   1        ADCCRL = temp_reg2;
 109   1        
 110   1        /* If the ADC clock is more than 4MHz, ADC module is not initialized. 
 111   1           To meet the conversion time spec value, adc clock is under 2MHz recommended.
 112   1        */
 113   1        /*
 114   1        while( (clock_sel >= 1) )
 115   1        {
 116   1          NOP;  // NOTE : clock_sel <= 2Mhz
C51 COMPILER V9.54   A96L41X_ADC                                                           04/16/2026 10:27:06 PAGE 3   

 117   1        }
 118   1      */
 119   1      
 120   1          
 121   1      }
