 212   3                temp_reg |= (val<<(pin<<1));
 213   3                
 214   3                P0FSRL = temp_reg;
 215   3              }
 216   2            break;
 217   2            case 1:
 218   2              if(pin > 0x3)
 219   2              {
 220   3                temp_reg = P1FSRH;
 221   3                temp_reg &= ~(0x3<<((pin-4)<<1));
 222   3                temp_reg |= (val<<((pin-4)<<1));
 223   3                
 224   3                P1FSRH = temp_reg;
 225   3              }
 226   2              else
 227   2              {
 228   3                temp_reg = P1FSRL;
 229   3                temp_reg &= ~(0x3<<(pin<<1));
 230   3                temp_reg |= (val<<(pin<<1));  
 231   3      
 232   3                P1FSRL = temp_reg;
 233   3              } 
 234   2            break;
 235   2            case 2:
 236   2              if(pin > 0x1)
 237   2              {
 238   3                temp_reg = P2FSR;
 239   3                temp_reg  &= ~(1<<pin);
 240   3                temp_reg  |= (val<<pin);
