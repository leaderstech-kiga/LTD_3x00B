  57          /**
  58          * @brief  Initialize GPIO(PCU) peripheral
  59          * @param      None
  60          * @return   None
  61          */
  62          void Port_Initial(void)
  63          {
  64   1          // P0 setting
  65   1          // P00:   C_VDD
  66   1          
  67   1          P0    = _1100_0000;   // 0 : Low, 1 : High
  68   1          P0OD  = _0000_0000;   // 0 : Disable, 1 : Enable (Open-drain)
  69   1          P0PU  = _0000_0000;   // 0 : Disable, 1 : Enable (Pull-up)
  70   1          P0IO  = _1100_0001;   // 0 : Input, 1 : Output
  71   1          P0FSRH  = 0
  72   1          | ( 0 << 6)       //P07     // 0 : I/O (EINT3), 1 : ICS1                  // LED_R        
  73   1          | ( 0 << 4)       //P06     // 0 : I/O (EINT2), 1 : ICS0                  // LED_G
  74   1          | ( 1 << 2)       //P05     // 0 : I/O, 1 : OP0P,                       // SENISNG OP0P
  75   1          | ( 1 << 0);      //P04     // 0 : I/O, 1 : OP0N                    // SENSING OP0N
  76   1          
  77   1          P0FSRL  = 0
  78   1          | ( 1 << 6)       //P03     // 0 : I/O, 1 : OP0OUT,   2 : AN3,      3 : Not used          // SENSING IN ADC 
  79   1          | ( 2 << 4)       //P02     // 0 : I/O, 1 : OP1P,   2 : AN2,      3 : Not used          // BAT_ADC
  80   1          | ( 0 << 2)       //P01     // 0 : I/O (EINT1), 1 : OP1N,  2 : AN1, 3 : Not used        // EMR_IO
  81   1          | ( 0 << 0);      //P00     // 0 : I/O (EINT0), 1 : OP1OUT,   2 : AN0,  3 : Not used      // C_VDD
  82   1          
  83   1          P0DB  = 0
  84   1          | ( 0 << 6)     //DBCLK[1:0]  // 00 : fx (SCLK),  01 : fx/4,  10 : fx/16, 11 : fx/64
  85   1          | ( 0 << 3)     //P07DB   // 0 : Disable, 1 : Enable
  86   1          | ( 0 << 2)     //P06DB   // 0 : Disable, 1 : Enable
  87   1          | ( 0 << 1)     //P01DB   // 0 : Disable, 1 : Enable
  88   1          | ( 0 << 0);    //P00DB   // 0 : Disable, 1 : Enable
  89   1          
  90   1          // P1 setting    
  91   1          // P14: /AUDIO_ON   
  92   1          P1    = _0001_0000;   // 0 : Low, 1 : High                // audio off
  93   1          P1OD  = _0000_0000;   // 0 : Disable, 1 : Enable (Open-drain)
  94   1          P1PU  = _0000_0100;   // 0 : Disable, 1 : Enable (Pull-up)
  95   1          P1IO  = _0011_0011;   // 0 : Input, 1 : Output
  96   1          
  97   1          P1FSRH  = 0
  98   1          | ( 1 << 2)       //P15  // 0 : I/O,  1 : LDO23,   2 : AN6, 3 : (SDA)           // LDO23
  99   1          | ( 0 << 0);      //P14  // 0 : I/O (EINT11), 1 : T1O/PWM1O,   2 : SCL, 3 : Not used    // /AUD ON
 100   1          
 101   1          P1FSRL  = 0
 102   1          | ( 0 << 6)       //P13  // 0 : I/O (EC1),  1 : (RXD/MISO)              // DSDA
 103   1          | ( 0 << 4)       //P12  // 0 : I/O (EC0),  1 : (TXD/MOSI)                // DSCL
 104   1          | ( 1 << 2)       //P11  // 0 : I/O (EINT10), 1 : T0O/PWM0O             // AUDIO SIG
 105   1          | ( 0 << 0);      //P10  // 0 : I/O,  1 : (SCK)                   // SENSE PW
 106   1      
 107   1          P12DB = 0
 108   1          | ( 0 << 5)     //P21DB   // 0 : Disable, 1 : Enable
 109   1          | ( 0 << 4)     //P20DB   // 0 : Disable, 1 : Enable
 110   1          | ( 0 << 2)     //P14DB   // 0 : Disable, 1 : Enable
 111   1          | ( 0 << 1)     //P11DB   // 0 : Disable, 1 : Enable
 112   1          | ( 0 << 0);      //P10DB   // 0 : Disable, 1 : Enable
 113   1      
 114   1          // P2 setting    
 115   1          //P20:  /CS   
 116   1          P2  = _0000_1111;   // 0 : Low, 1 : High
C51 COMPILER V9.54   A96L41X_GPIO                                                          04/10/2026 17:39:33 PAGE 3   

 117   1          P2OD  = _0000_0000;   // 0 : Disable, 1 : Enable (Open-drain)
 118   1          P2PU  = _0000_0000;   // 0 : Disable, 1 : Enable (Pull-up)
 119   1          P2IO  = _0000_1111;   // 0 : Input, 1 : Output
 120   1          
 121   1          P2FSR   = 0
 122   1          | ( 1 << 6)     // 0 : P23,  1 : TXD/MOSI,  2 : AN5,     3 : Not used         //mosi
 123   1          | ( 1 << 4)     // 0 : P22,  1 : RXD/MISO,  2 : AN4,     3 : Not used         // miso
 124   1          | ( 1 << 2)         // 0 : P21 (EC2),  1 : SCK,   2 : (SCL),     3 : Not used           // sck
 125   1          | ( 0 << 0);        // 0 : P20 (EINT12),  1 : T2O/PWM2O,   2 : SDA,     3 : Not used      // cs 
 126   1      
 127   1      }
