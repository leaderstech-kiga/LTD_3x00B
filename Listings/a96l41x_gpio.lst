 129          /**
 130          * @brief  Configures the selected port(x) pins as output pin.
 131          * @param    port  This parameter contains the pin port
 132          * @param    pin   This parameter contains the pin number
 133          * @param    mode  This parameter contains the pin mode(Push-Pull : 0, Open-Drain :1)
 134          * @return   None
 135          */
 136          void Port_SetOutputpin(uint8_t port, uint8_t pin, uint8_t mode)
 137          {
 138   1      
 139   1          switch(port)
 140   1          {
 141   2            case 0:
 142   2              P0IO |= (1<<pin);
 143   2              P0OD |= (mode<<pin);
 144   2            break;
 145   2            case 1:
 146   2              P1IO |= (1<<pin);
 147   2              P1OD |= (mode<<pin);
 148   2            break;
 149   2            case 2:
 150   2              P2IO |= (1<<pin);
 151   2              P2OD |= (mode<<pin);
 152   2            break;
 153   2            default:
 154   2            break;
 155   2          }
 156   1      }
