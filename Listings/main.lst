 894   1      
C51 COMPILER V9.54   MAIN                                                                  04/24/2026 14:37:15 PAGE 16  

 895   1          if (adc_avg == 0) return 0;   // 방어코드
 896   1      
 897   1          vbat_cv = ((uint32_t)VBGR_CV * ADC_FS) / adc_avg;
 898   1      
 899   1          // sanity clamp (optional)
 900   1          if (vbat_cv > 400) vbat_cv = 400;   // 4.00V 이상은 비정상
 901   1      
 902   1          return (uint16_t)vbat_cv;
 903   1      }
