 403          // 하드웨어를 초가화 한 후 ms 대기한다. 
 404          void hw_initial_Wait(int msec){
 405   1        
 406   1        GLOBAL_INTERRUPT_DIS();     
 407   1        hw_initial();
 408   1        
 409   1        CVDD_OFF;
 410   1        Port_SetOutputpin(PORT1, PIN3, 0); // CS 핀
 411   1      
 412   1        Delay_ms(msec);
 413   1        
 414   1          /* Enable INT */
 415   1        GLOBAL_INTERRUPT_EN();  
 416   1        
 417   1      }
