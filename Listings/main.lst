1648           * @return  None
1649           **********************************************************************/
1650          
1651          uint16_t Data_Avr(uint16_t *adc_data, uint8_t count){
1652   1        
1653   1        uint32_t temp = 0;
1654   1        uint8_t i;
1655   1        
1656   1        for(i=0; i<count ; i++){
1657   2          temp = temp + adc_data[i];
1658   2        }
1659   1        
1660   1        temp = (uint16_t)(temp / count);
1661   1        
1662   1        return temp;
1663   1        
1664   1      }
