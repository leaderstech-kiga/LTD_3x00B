1116          void Uart_Out_Int(uint16_t Value){
1117   1      
1118   1        uint16_t int_val;
1119   1        uint8_t tmp;
1120   1        
1121   1        if(Value > 9999){
1122   2          Value = 9999;
1123   2        }
1124   1        
1125   1        tmp = Value / 1000 + 48;
1126   1        USART_SendDataWithPolling(&tmp, 1);
1127   1        int_val= Value % 1000 ;
1128   1        tmp = (int_val/ 100 )+ 48;
1129   1        USART_SendDataWithPolling(&tmp, 1);
1130   1        int_val= Value % 100 ;
1131   1        tmp = (int_val/ 10 )+ 48;
1132   1        USART_SendDataWithPolling(&tmp, 1);
1133   1        int_val= Value % 10 ;
1134   1        tmp = (int_val/ 1) + 48;
1135   1        USART_SendDataWithPolling(&tmp, 1);
1136   1      }
