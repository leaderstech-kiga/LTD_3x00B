 692   1        Delay_ms(1);
 693   1        
 694   1        ADC_GetDataWithPolling(ADC_temp_data, ADC_MAX_BUFFER_SIZE);
 695   1        
 696   1        LDO_OFF;
 697   1      
 698   1        Temp_adc_data = Data_Avr(ADC_temp_data, ADC_MAX_BUFFER_SIZE);
 699   1        
 700   1        return Temp_adc_data;
 701   1        
 702   1      }
