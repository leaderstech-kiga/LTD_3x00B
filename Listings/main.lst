2068          
2069          uint16_t BAT_ADC_Avr(uint8_t buf_cnt){
2070   1        
2071   1        uint16_t Bat_ADC;
2072   1        
2073   1        uint32_t op;
2074   1        
2075   1        P0FSRL  = 0
2076   1          | ( 1 << 6)       //P03     // 0 : I/O, 1 : OP0OUT,   2 : AN3,      3 : Not used          // SENSING IN ADC 
2077   1          | ( 1 << 4)       //P02     // 0 : I/O, 1 : OP1P,   2 : AN2,      3 : Not used          // 
2078   1          | ( 1<< 2)       //P10     // 0 : I/O (EINT1),  1 : OP1N,  2 : AN1, 3 : Not used        // BAT_ADC
2079   1          | ( 0 << 0);      //P00     // 0 : I/O (EINT0), 1 : OP1OUT,   2 : AN0,  3 : Not used      // C_VDD
2080   1        
2081   1      
2082   1        NOP_20us_Delay(10); // 200us
2083   1      
2084   1        ADC_Initial(ADC_CLK_2M, ADC_SW_TRIG, ADC_INTERNAL_REF, ADC_LSB);  
2085   1        
2086   1        ADC_SelectChannel(ADC_VBGR);
2087   1      
2088   1        ADC_GetDataWithPolling(temp_data, buf_cnt);
2089   1        
2090   1        Data_Sorting(temp_data,buf_cnt);
2091   1        
2092   1        /* [BUG-04 FIX #3] Prevent division by zero if ADC returns 0 (BAT_ADC) */
2093   1        /* BEFORE: op=92; op*=1024; op/=temp_data[ADC_MAX_BUFFER_SIZE/2]; */
2094   1        if(temp_data[buf_cnt/2] == 0) {
2095   2          temp_data[buf_cnt/2] = 1;
2096   2        }
2097   1        op=92;
2098   1        op*=1024;
2099   1        op/=temp_data[ADC_MAX_BUFFER_SIZE/2];
2100   1        Bat_ADC=op;
2101   1      
2102   1        return Bat_ADC;
2103   1      }
