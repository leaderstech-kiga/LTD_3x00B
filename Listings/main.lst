1625          void Data_Sorting(uint16_t *adc_data, uint8_t count)
1626          {
1627   1        uint8_t i,j;
1628   1        uint16_t temp;
1629   1      
1630   1        for(i = 0; i < (count-1); i++)
1631   1        {
1632   2          for(j = i+1; j < count; j++)
1633   2          {
1634   3            
1635   3            if(adc_data[i] > adc_data[j])
1636   3            {
1637   4              temp = adc_data[i];
1638   4              adc_data[i]=adc_data[j];
1639   4              adc_data[j]=temp;
1640   4            }
1641   3          }
1642   2        }
1643   1      }
