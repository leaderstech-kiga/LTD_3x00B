 683   1          | ( 2<< 2)       //P10     // 0 : I/O (EINT1),  1 : OP1N,  2 : AN1, 3 : Not used        // BAT_ADC
 684   1          | ( 0 << 0);      //P00     // 0 : I/O (EINT0), 1 : OP1OUT,   2 : AN0,  3 : Not used      // C_VDD
 685   1        
 686   1        OP0_Enable(FALSE);
 687   1        OP1_Enable(FALSE);
 688   1        LDO_ON;
