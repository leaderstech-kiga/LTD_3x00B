 646          /**********************************************************************
 647           * @brief   Data_Avr
 648           * @param     None
 649           * @return  None
 650           **********************************************************************/
 651          // 평균 값 계산 함수 
 652          uint16_t Data_Avr(uint16_t *adc_data, uint8_t count){
 653   1        
 654   1        uint32_t temp = 0;
 655   1        uint8_t i;
 656   1        
 657   1        for(i=0; i<count ; i++){
 658   2          temp = temp + adc_data[i];
 659   2        }
 660   1        
 661   1        temp = (uint16_t)(temp / count);
 662   1        
 663   1        return temp;
 664   1        
 665   1      }
