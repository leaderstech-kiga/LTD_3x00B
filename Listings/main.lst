 775           * @return  None
 776           **********************************************************************/
 777          
 778          
 779          
 780          uint16_t Check_System(void)
 781          {
 782   1        int V25_On_adc_data= 0 , V25_Off_adc_data= 0;
 783   1        uint16_t System_Mode_Ck;
 784   1        
 785   1        // op amp  -> input 변경 
 786   1        P0FSRL  = 0
 787   1          | ( 2 << 6)       //P03     // 0 : I/O, 1 : OP0OUT,   2 : AN3,      3 : Not used          // SENSING IN ADC 
 788   1          | ( 2 << 4)       //P02     // 0 : I/O, 1 : OP1P,   2 : AN2,      3 : Not used              // Temperature_ADC
 789   1          | ( 2<< 2)        //P01     // 0 : I/O (EINT1), 1 : OP1N,  2 : AN1, 3 : Not used        // 
 790   1          | ( 0 << 0);      //P00     // 0 : I/O (EINT0), 1 : OP1OUT,   2 : AN0,  3 : Not used      // C_VDD
 791   1        
 792   1        OP0_Enable(FALSE);
 793   1        OP1_Enable(FALSE);
 794   1        LDO_ON;
 795   1        ADC_Initial(ADC_CLK_1M, ADC_SW_TRIG, ADC_INTERNAL_REF, ADC_LSB);   //ADC_INTERNAL_REF 를 사용하고 LDO_ON을
             - 제어했을때 adc 차이를 가지고 system mode 확인
 796   1        ADC_SelectChannel(ADC_CH3);
 797   1        
 798   1        Delay_ms(1);
 799   1        
 800   1        ADC_GetDataWithPolling(ADC_temp_data, sizeof(ADC_temp_data));
 801   1        
 802   1        LDO_OFF;
 803   1      
 804   1        V25_On_adc_data = Data_TrimmedMean(ADC_temp_data, sizeof(ADC_temp_data));
 805   1        
 806   1        Delay_ms(20);
 807   1        
 808   1        ADC_GetDataWithPolling(ADC_temp_data, sizeof(ADC_temp_data));
 809   1        V25_Off_adc_data = Data_TrimmedMean(ADC_temp_data, sizeof(ADC_temp_data));
 810   1      
 811   1        if( abs(V25_On_adc_data - V25_Off_adc_data) > System_Ck_Value){
 812   2          System_Mode_Ck = Temp_mode;
 813   2        }
 814   1        else{
 815   2          System_Mode_Ck = Dust_mode;
 816   2        }
 817   1      
 818   1        return System_Mode_Ck;
 819   1        
 820   1      }
