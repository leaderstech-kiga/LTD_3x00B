 701          /**********************************************************************
 702           * @brief   Data_Avr
 703           * @param     None
 704           * @return  None
 705           **********************************************************************/
 706          // 평균 값 계산 함수 
 707          uint16_t Data_Avr(uint16_t *adc_data, uint8_t count){
 708   1        
 709   1        uint32_t temp = 0;
 710   1        uint8_t i;
 711   1        
 712   1        if(count < 1){
C51 COMPILER V9.54   MAIN                                                                  04/24/2026 14:37:15 PAGE 13  

 713   2          return 0;
 714   2        }
 715   1        
 716   1        for(i=0; i<count ; i++){
 717   2          temp = temp + adc_data[i];
 718   2        }
 719   1        
 720   1        temp = temp / count;
 721   1        
 722   1        return temp;
 723   1        
 724   1      }
 725          
 726          void Data_Sorting(uint16_t *adc_data, uint8_t count)
 727          {
 728   1        uint8_t i,j;
 729   1        uint16_t temp;
 730   1      
 731   1        if(count < 1){
 732   2          return;
 733   2        }
 734   1        
 735   1        for(i = 0; i < (count-1); i++)
 736   1        {
 737   2          for(j = i+1; j < count; j++)
 738   2          {
 739   3            
 740   3            if(adc_data[i] > adc_data[j])
 741   3            {
 742   4              temp = adc_data[i];
 743   4              adc_data[i]=adc_data[j];
 744   4              adc_data[j]=temp;
 745   4            }
 746   3          }
 747   2        }
 748   1      }
 749          
 750          uint16_t Data_TrimmedMean(uint16_t *adc_data, uint8_t count){
 751   1      
 752   1        uint32_t temp = 0;
 753   1        uint8_t i;
 754   1        
 755   1        if(count < 3){
 756   2          return 0;
 757   2        }
 758   1        
 759   1        
 760   1        Data_Sorting(adc_data, count);
 761   1        
 762   1        for(i=1; i<(count -1) ; i++){
 763   2          temp = temp + adc_data[i];
 764   2        }
 765   1        
 766   1        temp = temp / (count -2);
 767   1        
 768   1        return temp;
 769   1        
 770   1      }
