 880          
 881          uint16_t Get_Bat_Voltage_cV(void)   // 단위: 0.01V
 882          {
 883   1          uint32_t adc_avg;
 884   1          uint32_t vbat_cv;
 885   1        
 886   1      
 887   1          ADC_Initial(ADC_CLK_2M, ADC_SW_TRIG, ADC_INTERNAL_REF, ADC_LSB);   //ADC_INTERNAL_REF 를 읽어 VBGR_CV 
