 124          void TIMER1_Int(void) interrupt T1_MATCH_VECT
 125          {
 126   1        uint8_t duty;
 127   1      
 128   1        Timer1_ClearInterruptFlag();
 129   1      
 130   1      
 131   1        if(Audio_start==0)
 132   1        { 
 133   2          AUDIO_ON;
 134   2          Read(Audio_addr);   
 135   2        
 136   2          Timer0_SetPPGDutyCounter(0);
 137   2          Timer0_Start();
 138   2          Audio_start=1;
 139   2        }
 140   1        else
 141   1        {
 142   2      
 143   2          if(Audio_length < Audio_max_length)
 144   2          {
 145   3            Read_c(read_data);
 146   3            duty = read_data[0];
 147   3            duty =duty>>1;
 148   3            if(duty >= 124)
 149   3              duty= 124;
 150   3             Timer0_SetPPGDutyCounter(duty);
 151   3             Audio_length++;
 152   3             Audio_addr++;
 153   3          }
 154   2          else
 155   2          {
 156   3            SLAVEDESELECT;
 157   3            AUDIO_OFF;
 158   3            Timer0_Stop();
 159   3          }
 160   2          
 161   2        }
 162   1          
 163   1        
 164   1      }
