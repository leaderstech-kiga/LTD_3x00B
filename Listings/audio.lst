 119          void TIMER1_Int(void) interrupt T1_MATCH_VECT
 120          {
 121   1        uint8_t duty;
 122   1      
 123   1        Timer1_ClearInterruptFlag();
 124   1      
 125   1      
 126   1        if(Audio_start==0)
 127   1        { 
 128   2          AUDIO_ON;
 129   2          Read(Audio_addr);   // SPI ŔĐ±â ¸í·É¸¸ ˝ĂŔŰ
 130   2        
 131   2          Timer0_SetPPGDutyCounter(0);
 132   2          Timer0_Start();
 133   2          Audio_start=1;
 134   2          // ˇç ŔĚ ˝ĂÁˇżŁ ľĆÁ÷ µĄŔĚĹÍ°ˇ PWMżˇ ąÝżµ ľČ µĘ
 135   2        }
 136   1        else
 137   1        {
 138   2      
 139   2          if(Audio_length < Audio_max_length)
 140   2          {
 141   3            Read_c(read_data);  // ´ŮŔ˝ ŔÎĹÍ·´Ć®żˇĽ­ µĄŔĚĹÍ Ľö˝Ĺ
 142   3            duty = read_data[0];  // 8bit ˇć 0~127 şŻČŻ
 143   3            duty =duty>>1;
 144   3            if(duty >= 124)
 145   3              duty= 124;
 146   3             Timer0_SetPPGDutyCounter(duty);
 147   3             Audio_length++;
 148   3             Audio_addr++;
 149   3          }
 150   2          else  // Audio_length >= Audio_max_length µµ´Ţ ˝Ă
 151   2          {
 152   3            SLAVEDESELECT;
 153   3            AUDIO_OFF;
 154   3            Timer0_Stop();
 155   3            Audio_start = 0;
 156   3            Audio_length = 0;
 157   3          }
 158   2          
 159   2        }
 160   1          
 161   1        
 162   1      }
