  74          /**********************************************************************
  75           * @brief   Audio_Initial
  76           * @param     None
  77           * @return  None
  78           **********************************************************************/
  79          void Audio_Initial(void)
  80          {
  81   1      
  82   1        if(SystemStatus==0)
  83   1          return;
  84   1        
  85   1        /* Timer0 PPG port (Alternative function) */
  86   1        Port_SetAlterFunctionpin(PORT1, PIN1, 0x1);     // PWM
  87   1        
  88   1            /* Timer0 initialize @ 4MHz */
  89   1        Timer0_Initial(T0_PPG_REPEAT_MODE, TIMER0_DIV1);  
  90   1         /* Timer0 PPG Polarity Start Low */
  91   1        Timer0_SetPPGPolarity(T0_START_HIGH); 
  92   1         /* Timer0 PPG Period Counter*/ 
  93   1          Timer0_SetPPGPeriodCounter(124);        // 125(31.2us, 32khz)   
  94   1        Timer0_SetPPGDutyCounter(50);
  95   1        
  96   1          /* Enable timer0 match INT */   
  97   1        Timer0_ConfigureInterrupt(FALSE);
  98   1        /* Timer0 start */
  99   1        //Timer0_Start(); 
 100   1      
 101   1      
 102   1            /* Timer1 initialize @ 4MHz */
 103   1        Timer1_Initial(T1_PPG_REPEAT_MODE, TIMER1_DIV1);  
 104   1         /* Timer1 PPG Polarity Start Low */
 105   1        Timer1_SetPPGPolarity(T1_START_HIGH); 
 106   1         /* Timer1 PPG Period Counter*/ 
 107   1        Timer1_SetPPGPeriodCounter(499);        //500(125us,8khz)
 108   1      
 109   1        Timer1_SetPPGDutyCounter(100);          
 110   1        
 111   1          /* Enable timer1 match INT */   
 112   1        Timer1_ConfigureInterrupt(TRUE);
 113   1        /* Timer1 start */
 114   1        //Timer1_Start(); 
 115   1      
 116   1      }
