 164          
 165          
 166          void Read_Audio_Length(uint16_t Audio_st_address)
 167          {
 168   1        unsigned long temp;
 169   1      
 170   1        Audio_addr=Audio_st_address + 40;
 171   1        Read_v(Audio_addr, read_data);
 172   1        Audio_max_length = read_data[0];          // Low byte
 173   1      
 174   1        Audio_addr=Audio_st_address + 41;
 175   1        Read_v(Audio_addr, read_data);  
 176   1        temp= read_data[0];
 177   1        temp = (temp << 8)&0xff00;     // High byte
 178   1        Audio_max_length |=temp;
