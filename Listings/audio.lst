  81          void Audio_Initial(void)
  82          {
  83   1      
  84   1        if(SystemStatus==0)
  85   1          return;
  86   1        
  87   1        /* Timer0 PPG port (Alternative function) */
  88   1        Port_SetAlterFunctionpin(PORT1, PIN1, 0x1);     // PWM
  89   1        
  90   1            /* Timer0 initialize @ 4MHz */
  91   1        Timer0_Initial(T0_PPG_REPEAT_MODE, TIMER0_DIV1);  
  92   1         /* Timer0 PPG Polarity Start Low */
  93   1        Timer0_SetPPGPolarity(T0_START_HIGH); 
  94   1         /* Timer0 PPG Period Counter*/ 
  95   1          Timer0_SetPPGPeriodCounter(124);        // 125(31.2us, 32khz)   
  96   1        Timer0_SetPPGDutyCounter(50);
  97   1        
  98   1          /* Enable timer0 match INT */   
  99   1        Timer0_ConfigureInterrupt(FALSE);
 100   1        /* Timer0 start */
 101   1        //Timer0_Start(); 
 102   1      
 103   1      
 104   1        
 105   1            /* Timer1 initialize @ 4MHz */
 106   1        Timer1_Initial(T1_PPG_REPEAT_MODE, TIMER1_DIV1);  
 107   1         /* Timer1 PPG Polarity Start Low */
 108   1        Timer1_SetPPGPolarity(T1_START_HIGH); 
 109   1         /* Timer1 PPG Period Counter*/ 
 110   1        Timer1_SetPPGPeriodCounter(499);        //500(125us,8khz)
 111   1      
 112   1        Timer1_SetPPGDutyCounter(100);          
 113   1        
 114   1          /* Enable timer1 match INT */   
 115   1        Timer1_ConfigureInterrupt(TRUE);
 116   1        /* Timer1 start */
